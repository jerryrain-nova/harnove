{
  "name": "harnove",
  "version": "4.2.0",
  "config_schema_version": 4,
  "version_policy": {
    "fix_or_optimization": "increment_patch_c",
    "new_feature": "increment_minor_b",
    "architecture_change": "increment_major_a"
  },
  "core_files": [
    "harnove-package.json",
    "harnove.config.example.json",
    "init.py",
    "run.ps1",
    "SKILL.md",
    "USAGE.md",
    "agents/openai.yaml",
    "adapters/cursor/harnove.md",
    "references/artifact-contracts.md",
    "scripts/harnove.py",
    "scripts/version_policy.py",
    "scripts/export_package.py",
    "scripts/self_test.py",
    "scripts/install_self_test.py",
    "scripts/package_self_test.py"
  ],
  "project_owned_paths": [
    "config.json",
    "install-manifest.json",
    "runtime/",
    "skill/",
    "iterations/",
    "improve/",
    "structure/",
    "custom/",
    ".agents/skills/harnove/",
    ".claude/skills/harnove/",
    ".cursor/commands/harnove.md"
  ]
}
